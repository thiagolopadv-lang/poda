# PODA — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores reais
# NUNCA faça commit do arquivo .env com valores reais

# =============================================
# WhatsApp / Meta (OBRIGATÓRIO)
# =============================================

# Token de acesso permanente da Meta Business API
# Obter em: developers.facebook.com → Seu App → WhatsApp → Configuração → Token de acesso
WHATSAPP_TOKEN=

# ID do número de telefone do WhatsApp Business
# Obter em: developers.facebook.com → Seu App → WhatsApp → Configuração → Phone number ID
WHATSAPP_PHONE_NUMBER_ID=

# Token de verificação do webhook (você define este valor — pode ser qualquer string)
# Use o mesmo valor ao configurar o webhook no painel da Meta
WHATSAPP_VERIFY_TOKEN=poda_verify_secret

# =============================================
# Jina Reader (OBRIGATÓRIO para URL → Markdown)
# =============================================

# API Key gratuita: cadastro em jina.ai → Settings → API Keys
# Sem a key: funciona com 10 req/min. Com a key: 100 req/min
JINA_API_KEY=

# =============================================
# Firecrawl (OPCIONAL — fallback para páginas JS)
# =============================================

# API Key: cadastro em firecrawl.dev → Dashboard → API Keys
# Plano gratuito: 500 páginas/mês. Plano Starter: $16/mês
FIRECRAWL_API_KEY=

# =============================================
# LlamaParse (OPCIONAL — fallback premium para PDFs complexos)
# =============================================

# API Key: cadastro em cloud.llamaindex.ai → API Keys
# Plano gratuito: 10.000 créditos/mês (~3.300 páginas)
LLAMA_CLOUD_API_KEY=

# =============================================
# Configurações Gerais
# =============================================

# Taxa de câmbio USD → BRL para exibição de custos
# Atualizar manualmente ou integrar com API do BACEN no futuro
USD_TO_BRL=5.70
